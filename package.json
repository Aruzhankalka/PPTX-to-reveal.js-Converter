{
  "name": "pptx-revealjs-converter",
  "version": "1.0.0",
  "description": "PPTX to reveal.js converter — Interdisciplinary SW-Dev Project, Hof University",
  "main": "src/app.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "jest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.{js,html,css}\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,html,css}\" \"tests/**/*.js\""
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ajv": "^8.20.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "fontkit": "^2.0.4",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "reveal.js": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.3.0",
    "eslint-plugin-security": "^4.0.1",
    "form-data": "^4.0.5",
    "jest": "^30.3.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
